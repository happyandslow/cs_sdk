// Per-PE loopback kernel for the SdkCompiler (memcpy) path.
//
// A simple loopback over the memcpy framework:
//   host memcpy_h2d  →  buf[]  →  host memcpy_d2h
//
// No PE-side computation is needed.  The memcpy module handles the DMA
// automatically once `buf` is exported as a symbol.

param memcpyParams: comptime_struct;
param pe_length: u16;

const sys_mod = @import_module("<memcpy/memcpy>", memcpyParams);

// Loopback buffer: H2D writes here, D2H reads from here.
var buf = @zeros([pe_length]f32);

// Pointer exported as the "buf" memcpy symbol.
// @export_symbol requires a [*]f32 (pointer), not a [N]f32 (array).
var ptr_buf : [*]f32 = &buf;

comptime {
  @export_symbol(ptr_buf, "buf");
}
