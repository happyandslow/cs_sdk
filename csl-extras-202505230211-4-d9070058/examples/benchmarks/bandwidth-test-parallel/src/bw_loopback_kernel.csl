// Per-PE loopback kernel for direct-link bandwidth testing.
//
// Receives pe_length f32 wavelets on in_color (from demux via WEST edge),
// stores them in a local buffer, then sends them back on out_color (via EAST
// edge to mux). Used for round-trip (H2D→D2H) bandwidth measurement.
//
// Activation: recv task is started at compile time. The cycle is:
//   recv -> (DMA complete) -> send -> (DMA complete) -> done (single pass)

param in_color:  color;
param out_color: color;
param pe_length: u16;

const input_q  = @get_input_queue(0);
const output_q = @get_output_queue(0);

// Local buffer: stores one batch of pe_length f32 values.
var buf = @zeros([pe_length]f32);

// DSDs (all extents are pe_length, a compile-time param).
const mem_dsd = @get_dsd(mem1d_dsd, .{.base_address = &buf, .extent = pe_length});
const in_dsd  = @get_dsd(fabin_dsd,  .{.extent       = pe_length,
                                        .fabric_color  = in_color,
                                        .input_queue   = input_q});
const out_dsd = @get_dsd(fabout_dsd, .{.extent        = pe_length,
                                        .fabric_color  = out_color,
                                        .output_queue  = output_q});

const recv_id = @get_local_task_id(8);
const send_id = @get_local_task_id(9);

// Step 1: receive pe_length wavelets from fabric into local buf.
task recv() void {
  @mov32(mem_dsd, in_dsd, .{.async = true, .activate = send_id});
}

// Step 2: send pe_length wavelets from buf back to fabric.
task send() void {
  @mov32(out_dsd, mem_dsd, .{.async = true});
  // Single pass: do not re-activate recv (router state is consumed after one pass).
}

comptime {
  @bind_local_task(recv, recv_id);
  @bind_local_task(send, send_id);
  @activate(recv_id);

  @initialize_queue(input_q, .{.color = in_color});
  if (@is_arch("wse3")) {
    @initialize_queue(output_q, .{.color = out_color});
  }
}
