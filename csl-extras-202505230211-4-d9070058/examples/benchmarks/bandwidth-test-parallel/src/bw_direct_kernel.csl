// Per-PE bandwidth measurement kernel for direct-link testing.
//
// Receives buf_size * num_batches f32 wavelets on in_color, discarding data
// after each batch (reusing the same small buffer). This allows measuring
// bandwidth for transfers much larger than the PE's SRAM.
//
// Records on-device timestamps before the first batch and after the last,
// then sends 4 f32 of packed timing data out on out_color.
//
// Timestamp packing (same as bandwidth-test/bw_sync_kernel.csl):
//   time_buf_f32[0] = {tscStart[1], tscStart[0]}
//   time_buf_f32[1] = {tscEnd[0],   tscStart[2]}
//   time_buf_f32[2] = {tscEnd[2],   tscEnd[1]}
//   time_buf_f32[3] = 0  (padding; ports require even wavelet count)
//
// Flow:
//   startup -> enable TSC -> activate recv
//   recv    -> DMA receive buf_size wavelets -> activate batch_done
//   batch_done -> record time_start (first time only)
//             -> if batches remaining: DMA receive again -> activate batch_done
//             -> else: activate done
//   done    -> record time_end -> pack timestamps -> send 4 f32 via out_color
//
// Note: time_start is recorded after the first batch completes (not before),
// so the measurement excludes host-side startup latency.  Bandwidth is
// computed over (num_batches - 1) batches of steady-state transfer.

param in_color:  comptime_int;
param out_color: comptime_int;
param buf_size:  u16;    // number of f32 per batch (size of local buffer)
param num_batches: u16;  // number of batches to receive

const in_color_obj  = @get_color(in_color);
const out_color_obj = @get_color(out_color);

const timestamp = @import_module("<time>");

const input_q  = @get_input_queue(0);
const output_q = @get_output_queue(0);

// Local buffer: reused for every batch (data is discarded).
var buf = @zeros([buf_size]f32);

// TSC buffers (each is u16[3] = 48 bits).
var tscStartBuffer = @zeros([timestamp.tsc_size_words]u16);
var tscEndBuffer   = @zeros([timestamp.tsc_size_words]u16);

// Packed timing output: 4 f32 words (3 data + 1 padding).
var time_buf_f32 = @zeros([4]f32);

// Batch counter.
var batches_remaining: u16 = num_batches;

// DSDs
const mem_dsd = @get_dsd(mem1d_dsd, .{ .base_address = &buf, .extent = buf_size });
const in_dsd  = @get_dsd(fabin_dsd, .{ .extent       = buf_size,
                                        .fabric_color  = in_color_obj,
                                        .input_queue   = input_q });

const time_mem_dsd = @get_dsd(mem1d_dsd, .{ .base_address = &time_buf_f32, .extent = 4 });
const time_out_dsd = @get_dsd(fabout_dsd, .{ .extent       = 4,
                                              .fabric_color  = out_color_obj,
                                              .output_queue  = output_q });

// Task IDs
const startup_id    = @get_local_task_id(7);
const recv_id       = @get_local_task_id(8);
const batch_done_id = @get_local_task_id(9);
const done_id       = @get_local_task_id(10);

// Step 0: enable the timestamp counter, then activate recv.
task startup() void {
  timestamp.enable_tsc();
  @activate(recv_id);
}

// Step 1: DMA-receive first batch (no timestamp yet — host may not have started sending).
task recv() void {
  batches_remaining -= 1;
  @mov32(mem_dsd, in_dsd, .{ .async = true, .activate = batch_done_id });
}

// Step 2: called after each batch completes.
// Records time_start after the first batch (when data is flowing steadily),
// then loops for remaining batches or finishes.
task batch_done() void {
  if (batches_remaining == num_batches - 1) {
    // First batch just completed — data is now flowing. Record start time.
    timestamp.get_timestamp(&tscStartBuffer);
  }
  if (batches_remaining > 0) {
    batches_remaining -= 1;
    @mov32(mem_dsd, in_dsd, .{ .async = true, .activate = batch_done_id });
  } else {
    @activate(done_id);
  }
}

// Step 3: record time_end, pack timestamps, send timing data out.
task done() void {
  timestamp.get_timestamp(&tscEndBuffer);

  var lo_: u16 = 0;
  var hi_: u16 = 0;

  lo_ = tscStartBuffer[0];
  hi_ = tscStartBuffer[1];
  time_buf_f32[0] = @bitcast(f32, (@as(u32, hi_) << @as(u16, 16)) | @as(u32, lo_));

  lo_ = tscStartBuffer[2];
  hi_ = tscEndBuffer[0];
  time_buf_f32[1] = @bitcast(f32, (@as(u32, hi_) << @as(u16, 16)) | @as(u32, lo_));

  lo_ = tscEndBuffer[1];
  hi_ = tscEndBuffer[2];
  time_buf_f32[2] = @bitcast(f32, (@as(u32, hi_) << @as(u16, 16)) | @as(u32, lo_));

  @mov32(time_out_dsd, time_mem_dsd, .{ .async = true });
}

comptime {
  @bind_local_task(startup, startup_id);
  @bind_local_task(recv, recv_id);
  @bind_local_task(batch_done, batch_done_id);
  @bind_local_task(done, done_id);
  @activate(startup_id);

  @initialize_queue(input_q, .{ .color = in_color_obj });
  if (@is_arch("wse3")) {
    @initialize_queue(output_q, .{ .color = out_color_obj });
  }
}
