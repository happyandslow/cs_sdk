// Layout for the SdkCompiler (memcpy) path of bandwidth-test-parallel.
//
// Topology: width columns × height rows of loopback PEs.
//   host --[memcpy H2D]--> buf[pe_length] --[memcpy D2H]--> host
//
// Compile flags expected by compile_single.py:
//   --arch wse3
//   --fabric-dims=<width+7>,<height+2>  (3 west + width core + 2 east + 1 extra)
//   --fabric-offsets=4,1
//   --params=width:<W>,height:<H>,pe_length:<N>
//   --memcpy --channels=<C>

param width:     i16;
param height:    i16;
param pe_length: i16;

const memcpy = @import_module("<memcpy/get_params>", .{
  .width  = width,
  .height = height,
});

layout {
  @set_rectangle(width, height);

  var py: i16 = 0;
  while (py < height) : (py += 1) {
    var px: i16 = 0;
    while (px < width) : (px += 1) {
      const memcpyParams = memcpy.get_params(px);
      @set_tile_code(px, py, "bw_kernel.csl", .{
        .pe_length    = @as(u16, pe_length),
        .memcpyParams = memcpyParams,
      });
    }
  }

  // Export the loopback buffer symbol so the host can H2D/D2H to it.
  @export_name("buf", [*]f32, true);
}
